{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@epubdoctor/shared-types": ["packages/shared-types/src"],
      "@epubdoctor/shared-ui": ["packages/shared-ui/src"],
      "@epubdoctor/shared-worker-runtime": ["packages/shared-worker-runtime/src"]
    }
  }
}
